{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "HEVN",
  "description": "Documentation for HEVN products, including the CLI and REST API surfaces used by integrations.",
  "colors": {
    "primary": "#256FAD",
    "light": "#3C8DCE",
    "dark": "#1B527F"
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript"
      ],
      "defaults": "required"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "agent-workflows",
              "configuration"
            ]
          },
          {
            "group": "Core workflows",
            "pages": [
              "commands/account",
              "commands/contacts",
              "commands/money-movement",
              "commands/invoices",
              "commands/contracts",
              "commands/cards-banks"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "api-reference/app-api",
              "api-reference/mcp-api",
              "api-reference/public-api",
              "development"
            ]
          }
        ]
      },
      {
        "tab": "REST API",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Generated API Reference",
            "openapi": "openapi.json"
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Book a call",
        "href": "https://calendly.com/hevn/hevn"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.gethevn.com"
    }
  }
}
